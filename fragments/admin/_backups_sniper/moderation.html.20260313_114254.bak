<!-- ENHANCED ADMIN MODERATION - PRODUCTION MODULE -->
<style data-fragment-style="admin_moderation">
/* ═══════════════════════════════════════════════════════════════════════════════ */
/* COLOR & THEME VARIABLES */
/* ═══════════════════════════════════════════════════════════════════════════════ */

:root {
  --primary-gold: #d4af37;
  --primary-dark: #1a1a2e;
  --secondary-dark: #16213e;
  --accent-blue: #0f3460;
  --success: #10b981;
  --warning: #f59e0b;
  --danger: #ef4444;
  --pending: #ec4899;
  --text-light: #e4e4e7;
  --text-muted: #9ca3af;
  --bg-primary: #0f172a;
  --bg-secondary: #1e293b;
  --bg-tertiary: #334155;
  --transition-fast: 0.15s ease;
  --transition-smooth: 0.3s cubic-bezier(0.4, 0, 0.2, 1);
  --transition-slow: 0.5s cubic-bezier(0.4, 0, 0.2, 1);
}

/* ═══════════════════════════════════════════════════════════════════════════════ */
/* STATS SECTION */
/* ═══════════════════════════════════════════════════════════════════════════════ */

.admin-stats {
  display: grid;
  grid-template-columns: repeat(auto-fit, minmax(200px, 1fr));
  gap: 16px;
  margin-bottom: 32px;
}

.stat-card {
  background: rgba(255, 255, 255, 0.05);
  border: 1px solid rgba(212, 175, 55, 0.2);
  padding: 24px;
  border-radius: 12px;
  backdrop-filter: blur(10px);
  transition: all var(--transition-smooth);
  position: relative;
  overflow: hidden;
}

.stat-card::before {
  content: '';
  position: absolute;
  top: -50%;
  right: -50%;
  width: 200%;
  height: 200%;
  background: radial-gradient(circle, rgba(212, 175, 55, 0.1) 0%, transparent 70%);
  pointer-events: none;
}

.stat-card:hover {
  border-color: var(--primary-gold);
  transform: translateY(-4px);
  box-shadow: 0 12px 24px rgba(212, 175, 55, 0.1);
}

.stat-number {
  font-size: 2.5rem;
  font-weight: 700;
  color: var(--primary-gold);
  margin-bottom: 8px;
  font-variant-numeric: tabular-nums;
}

.stat-label {
  font-size: 0.875rem;
  color: var(--text-muted);
  text-transform: uppercase;
  letter-spacing: 0.05em;
  font-weight: 500;
}

/* ═══════════════════════════════════════════════════════════════════════════════ */
/* FILTERS & CONTROLS */
/* ═══════════════════════════════════════════════════════════════════════════════ */

.admin-controls {
  background: rgba(255, 255, 255, 0.03);
  border: 1px solid rgba(212, 175, 55, 0.1);
  border-radius: 12px;
  padding: 24px;
  margin-bottom: 32px;
  backdrop-filter: blur(10px);
}

.admin-search {
  margin-bottom: 20px;
}

.admin-search input {
  width: 100%;
  padding: 12px 16px;
  background: rgba(255, 255, 255, 0.08);
  border: 1px solid rgba(212, 175, 55, 0.2);
  border-radius: 8px;
  color: var(--text-light);
  font-size: 1rem;
  transition: all var(--transition-smooth);
}

.admin-search input::placeholder {
  color: var(--text-muted);
}

.admin-search input:focus {
  outline: none;
  border-color: var(--primary-gold);
  background: rgba(255, 255, 255, 0.12);
  box-shadow: 0 0 0 3px rgba(212, 175, 55, 0.1);
}

.admin-filter-group {
  display: flex;
  gap: 8px;
  margin-bottom: 16px;
  flex-wrap: wrap;
}

.filter-btn {
  padding: 8px 16px;
  background: rgba(255, 255, 255, 0.05);
  border: 1px solid rgba(212, 175, 55, 0.2);
  color: var(--text-light);
  border-radius: 6px;
  cursor: pointer;
  font-size: 0.875rem;
  font-weight: 500;
  transition: all var(--transition-fast);
  white-space: nowrap;
}

.filter-btn:hover {
  background: rgba(212, 175, 55, 0.1);
  border-color: var(--primary-gold);
  transform: translateY(-2px);
}

.filter-btn.active {
  background: var(--primary-gold);
  border-color: var(--primary-gold);
  color: var(--bg-primary);
  font-weight: 600;
}

.control-row {
  display: flex;
  gap: 12px;
  flex-wrap: wrap;
  margin-bottom: 16px;
}

.form-select {
  padding: 8px 12px;
  background: rgba(255, 255, 255, 0.08);
  border: 1px solid rgba(212, 175, 55, 0.2);
  color: var(--text-light);
  border-radius: 6px;
  font-size: 0.875rem;
  cursor: pointer;
  transition: all var(--transition-smooth);
}

.form-select:focus {
  outline: none;
  border-color: var(--primary-gold);
  background: rgba(255, 255, 255, 0.12);
}

/* ═══════════════════════════════════════════════════════════════════════════════ */
/* ACTION BUTTONS */
/* ═══════════════════════════════════════════════════════════════════════════════ */

.admin-actions {
  display: grid;
  grid-template-columns: repeat(auto-fit, minmax(140px, 1fr));
  gap: 8px;
  margin-top: 16px;
}

.admin-btn {
  padding: 10px 16px;
  border: none;
  border-radius: 6px;
  cursor: pointer;
  font-size: 0.875rem;
  font-weight: 600;
  transition: all var(--transition-smooth);
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 6px;
  white-space: nowrap;
}

.admin-btn-primary {
  background: var(--primary-gold);
  color: var(--bg-primary);
}

.admin-btn-primary:hover {
  transform: translateY(-2px);
  box-shadow: 0 8px 16px rgba(212, 175, 55, 0.3);
}

.admin-btn-secondary {
  background: rgba(212, 175, 55, 0.1);
  color: var(--primary-gold);
  border: 1px solid rgba(212, 175, 55, 0.3);
}

.admin-btn-secondary:hover {
  background: rgba(212, 175, 55, 0.2);
  border-color: var(--primary-gold);
  transform: translateY(-2px);
}

.admin-btn-success {
  background: var(--success);
  color: white;
}

.admin-btn-success:hover {
  filter: brightness(1.1);
  transform: translateY(-2px);
}

.admin-btn-danger {
  background: var(--danger);
  color: white;
}

.admin-btn-danger:hover {
  filter: brightness(1.1);
  transform: translateY(-2px);
}

.admin-btn:disabled {
  opacity: 0.5;
  cursor: not-allowed;
  transform: none;
}

/* ═══════════════════════════════════════════════════════════════════════════════ */
/* MEMORY GRID & CARD LAYOUT */
/* ═══════════════════════════════════════════════════════════════════════════════ */

.admin-grid {
  display: grid;
  grid-template-columns: repeat(auto-fill, minmax(320px, 1fr));
  gap: 24px;
  margin-bottom: 32px;
}

.admin-memory-card {
  background: var(--bg-secondary);
  border: 1px solid rgba(212, 175, 55, 0.1);
  border-radius: 12px;
  overflow: hidden;
  transition: all var(--transition-smooth);
  display: flex;
  flex-direction: column;
  height: 100%;
  position: relative;
}

.admin-memory-card:hover {
  border-color: var(--primary-gold);
  transform: translateY(-8px);
  box-shadow: 0 20px 40px rgba(212, 175, 55, 0.15);
}

/* ═══════════════════════════════════════════════════════════════════════════════ */
/* IMAGE/MEDIA CONTAINER - PROPERLY STRUCTURED */
/* ═══════════════════════════════════════════════════════════════════════════════ */

.admin-memory-media {
  position: relative;
  width: 100%;
  padding-bottom: 100%; /* 1:1 aspect ratio - prevents layout shift */
  background: linear-gradient(135deg, rgba(0,0,0,0.3), rgba(0,0,0,0.1));
  overflow: hidden;
}

.admin-memory-media img,
.admin-memory-media video {
  position: absolute;
  top: 0;
  left: 0;
  width: 100%;
  height: 100%;
  object-fit: cover;
  object-position: center;
  transition: transform var(--transition-smooth);
  display: block;
}

/* Smooth zoom on hover */
.admin-memory-card:hover .admin-memory-media img,
.admin-memory-card:hover .admin-memory-media video {
  transform: scale(1.05);
}

/* ═══════════════════════════════════════════════════════════════════════════════ */
/* STATUS BADGE */
/* ═══════════════════════════════════════════════════════════════════════════════ */

.admin-memory-status {
  position: absolute;
  top: 12px;
  right: 12px;
  padding: 6px 12px;
  border-radius: 6px;
  font-size: 0.75rem;
  font-weight: 700;
  letter-spacing: 0.05em;
  text-transform: uppercase;
  backdrop-filter: blur(8px);
  z-index: 10;
  display: flex;
  align-items: center;
  gap: 4px;
}

.status-approved {
  background: rgba(16, 185, 129, 0.9);
  color: white;
}

.status-pending {
  background: rgba(236, 72, 153, 0.9);
  color: white;
}

.status-trash {
  background: rgba(239, 68, 68, 0.9);
  color: white;
}

.status-featured {
  background: rgba(212, 175, 55, 0.9);
  color: var(--bg-primary);
}

/* ═══════════════════════════════════════════════════════════════════════════════ */
/* BULK SELECT CHECKBOX */
/* ═══════════════════════════════════════════════════════════════════════════════ */

.bulk-checkbox-wrapper {
  position: absolute;
  top: 12px;
  left: 12px;
  z-index: 20;
  background: rgba(0,0,0,0.4);
  padding: 4px;
  border-radius: 4px;
  backdrop-filter: blur(4px);
}

.bulk-checkbox-wrapper input {
  width: 20px;
  height: 20px;
  accent-color: var(--primary-gold);
  cursor: pointer;
}

/* ═══════════════════════════════════════════════════════════════════════════════ */
/* CARD INFO SECTION */
/* ═══════════════════════════════════════════════════════════════════════════════ */

.admin-memory-info {
  display: flex;
  flex-direction: column;
  gap: 12px;
  padding: 16px;
  flex-grow: 1;
}

.admin-memory-name {
  font-size: 1rem;
  font-weight: 700;
  color: var(--text-light);
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.admin-memory-caption {
  font-size: 0.875rem;
  color: var(--text-muted);
  line-height: 1.4;
  display: -webkit-box;
  -webkit-line-clamp: 2;
  -webkit-box-orient: vertical;
  overflow: hidden;
  min-height: 2.8em;
}

/* ═══════════════════════════════════════════════════════════════════════════════ */
/* METADATA DISPLAY */
/* ═══════════════════════════════════════════════════════════════════════════════ */

.admin-memory-meta {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 8px;
  font-size: 0.75rem;
  color: var(--text-muted);
  padding: 8px;
  background: rgba(0, 0, 0, 0.2);
  border-radius: 6px;
}

.admin-memory-meta span {
  display: flex;
  align-items: center;
  gap: 4px;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

/* ═══════════════════════════════════════════════════════════════════════════════ */
/* ACTION BUTTONS IN CARD */
/* ═══════════════════════════════════════════════════════════════════════════════ */

.admin-memory-actions {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 8px;
  padding: 12px 16px;
  border-top: 1px solid rgba(212, 175, 55, 0.1);
  background: rgba(0, 0, 0, 0.2);
}

.admin-memory-actions button {
  padding: 8px 12px;
  border: none;
  border-radius: 6px;
  font-size: 0.75rem;
  font-weight: 600;
  cursor: pointer;
  transition: all var(--transition-fast);
  text-transform: uppercase;
  letter-spacing: 0.03em;
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 4px;
}

.approve-btn {
  background: var(--success);
  color: white;
}

.approve-btn:hover:not(:disabled) {
  filter: brightness(1.1);
  transform: scale(1.02);
}

.delete-btn {
  background: var(--danger);
  color: white;
}

.delete-btn:hover:not(:disabled) {
  filter: brightness(1.1);
  transform: scale(1.02);
}

.restore-btn {
  background: var(--warning);
  color: white;
}

.restore-btn:hover:not(:disabled) {
  filter: brightness(1.1);
  transform: scale(1.02);
}

.download-btn {
  background: var(--accent-blue);
  color: var(--text-light);
}

.download-btn:hover {
  background: rgba(15, 52, 96, 0.8);
  transform: scale(1.02);
}

.edit-btn {
  background: rgba(212, 175, 55, 0.2);
  color: var(--primary-gold);
}

.edit-btn:hover:not(:disabled) {
  background: rgba(212, 175, 55, 0.3);
  transform: scale(1.02);
}

/* ═══════════════════════════════════════════════════════════════════════════════ */
/* LOAD MORE & PAGINATION */
/* ═══════════════════════════════════════════════════════════════════════════════ */

.load-more-wrap {
  text-align: center;
  padding: 20px;
  margin-top: 25px;
}

.load-more-btn {
  padding: 12px 32px;
  background: linear-gradient(135deg, var(--primary-gold), #f59e0b);
  color: var(--bg-primary);
  border: none;
  border-radius: 8px;
  font-weight: 700;
  cursor: pointer;
  transition: all var(--transition-smooth);
  font-size: 1rem;
}

.load-more-btn:hover {
  transform: translateY(-4px);
  box-shadow: 0 12px 24px rgba(212, 175, 55, 0.3);
}

.load-more-btn:disabled {
  opacity: 0.5;
  cursor: not-allowed;
  transform: none;
}

/* ═══════════════════════════════════════════════════════════════════════════════ */
/* INLINE EDITING */
/* ═══════════════════════════════════════════════════════════════════════════════ */

.inline-editable {
  cursor: pointer;
  border: 1px dashed transparent;
  padding: 2px 4px;
  border-radius: 4px;
  transition: all var(--transition-smooth);
}

.inline-editable:hover {
  border-color: var(--primary-gold);
  background: rgba(212, 175, 55, 0.1);
}

.inline-editable.editing {
  background: rgba(255,255,255,0.1);
  border-color: var(--primary-gold);
}

.inline-edit-input {
  background: rgba(255,255,255,0.1);
  border: 1px solid var(--primary-gold);
  color: var(--text-light);
  padding: 4px 8px;
  border-radius: 6px;
  font-family: inherit;
  font-size: inherit;
  width: 100%;
}

/* ═══════════════════════════════════════════════════════════════════════════════ */
/* EMPTY STATE */
/* ═══════════════════════════════════════════════════════════════════════════════ */

.admin-grid-empty {
  grid-column: 1 / -1;
  text-align: center;
  padding: 60px 20px;
  color: var(--text-muted);
}

/* ═══════════════════════════════════════════════════════════════════════════════ */
/* RESPONSIVE DESIGN */
/* ═══════════════════════════════════════════════════════════════════════════════ */

@media (max-width: 768px) {
  .admin-grid {
    grid-template-columns: repeat(auto-fill, minmax(280px, 1fr));
    gap: 16px;
  }

  .admin-stats {
    grid-template-columns: repeat(2, 1fr);
  }

  .admin-memory-actions {
    grid-template-columns: 1fr;
  }

  .admin-actions {
    grid-template-columns: 1fr;
  }

  .admin-filter-group {
    flex-direction: column;
  }

  .filter-btn {
    width: 100%;
  }
}

@media (max-width: 480px) {
  .admin-grid {
    grid-template-columns: 1fr;
  }

  .stat-number {
    font-size: 2rem;
  }

  .admin-memory-actions {
    grid-template-columns: 1fr;
  }
}

@media (prefers-reduced-motion: reduce) {
  * {
    animation-duration: 0.01ms !important;
    animation-iteration-count: 1 !important;
    transition-duration: 0.01ms !important;
  }
}
</style>

<script data-fragment-script="admin_moderation">
// ═══════════════════════════════════════════════════════════════════════════════
// MODERATION PANEL - STATE MANAGEMENT
// ═══════════════════════════════════════════════════════════════════════════════

if (typeof state !== 'undefined') {
  Object.assign(state, {
    adminFilter: state.adminFilter || 'all',
    adminSort: state.adminSort || 'newest',
    adminSearch: state.adminSearch || '',
    adminLimit: state.adminLimit || 30,
    adminPage: state.adminPage || 1,
    adminHasMore: typeof state.adminHasMore !== 'undefined' ? state.adminHasMore : true,
    adminBulkMode: typeof state.adminBulkMode !== 'undefined' ? state.adminBulkMode : false,
    adminSelectedIds: state.adminSelectedIds || new Set(),
  });
}

// ═══════════════════════════════════════════════════════════════════════════════
// RENDER MODERATION PANEL HTML
// ═══════════════════════════════════════════════════════════════════════════════

function renderModerationPanelHtml() {
  return `
    <div class="admin-stats" id="adminStats">
      <div class="stat-card">
        <div class="stat-number" id="statTotal">0</div>
        <div class="stat-label">Total Uploads</div>
      </div>
      <div class="stat-card">
        <div class="stat-number" id="statApproved">0</div>
        <div class="stat-label">Approved</div>
      </div>
      <div class="stat-card">
        <div class="stat-number" id="statPending">0</div>
        <div class="stat-label">Pending</div>
      </div>
      <div class="stat-card">
        <div class="stat-number" id="statStorage">0 MB</div>
        <div class="stat-label">Storage Used</div>
      </div>
    </div>
    
    <div class="admin-controls">
      <div class="admin-search">
        <input type="text" id="adminSearch" placeholder="🔍 Search by name, caption, type..." />
      </div>
      <div class="admin-filter-group" id="adminFilterGroup">
        <button class="filter-btn active" data-admin-filter="all">All</button>
        <button class="filter-btn" data-admin-filter="approved">✓ Approved</button>
        <button class="filter-btn" data-admin-filter="pending">⏳ Pending</button>
        <button class="filter-btn" data-admin-filter="featured">⭐ Featured</button>
        <button class="filter-btn" data-admin-filter="trash">🗑 Trash</button>
      </div>
      <div class="control-row">
        <select class="form-select" id="adminSort">
          <option value="newest">📅 Newest First</option>
          <option value="oldest">📅 Oldest First</option>
          <option value="likes">❤️ Most Liked</option>
        </select>
        <select class="form-select" id="adminPageSize">
          <option value="30">30 per page</option>
          <option value="60">60 per page</option>
        </select>
      </div>
      <div class="admin-actions">
        <button class="admin-btn admin-btn-secondary" id="bulkSelectToggle" onclick="toggleBulkSelect()">☐ Bulk Select: OFF</button>
        <button class="admin-btn admin-btn-success" onclick="bulkActionPrompt('approve')">✓ Approve</button>
        <button class="admin-btn admin-btn-danger" onclick="bulkActionPrompt('trash')">🗑 Trash</button>
        <button class="admin-btn admin-btn-secondary" onclick="bulkActionPrompt('restore')">↩ Restore</button>
        <button class="admin-btn admin-btn-secondary" onclick="bulkActionPrompt('setType')">📁 Category</button>
        <button class="admin-btn admin-btn-secondary" onclick="bulkActionPrompt('feature')">⭐ Feature</button>
        <button class="admin-btn admin-btn-secondary" onclick="bulkActionPrompt('unfeature')">☆ Unfeature</button>
      </div>
    </div>
    
    <div class="admin-grid" id="adminGrid"></div>
    
    <div class="load-more-wrap">
      <button class="load-more-btn" id="adminLoadMoreBtn" onclick="adminLoadMore()">Load More</button>
    </div>
  `;
}

// ═══════════════════════════════════════════════════════════════════════════════
// INITIALIZE MODERATION PANEL
// ═══════════════════════════════════════════════════════════════════════════════

function initModerationPanelContent() {
  console.log('✅ Initializing Moderation Panel...');
  
  const panel = document.getElementById('panelModeration');
  if (!panel) {
    console.error('❌ panelModeration element not found');
    return;
  }
  
  const hasContent = panel.innerHTML.trim().length > 100;
  
  if (!hasContent) {
    panel.innerHTML = renderModerationPanelHtml();
  }
  
  setTimeout(() => {
    setupModerationEventListeners();
    loadAdminMemories(true);
  }, 50);
}

function setupModerationEventListeners() {
  console.log('✅ Setting up event listeners...');
  
  // Search
  const searchInput = document.getElementById('adminSearch');
  if (searchInput && !searchInput.dataset.listenerAdded) {
    searchInput.dataset.listenerAdded = '1';
    searchInput.addEventListener('input', debounce(() => {
      state.adminSearch = searchInput.value;
      loadAdminMemories(true);
    }, 300));
  }
  
  // Filters
  const filterGroup = document.getElementById('adminFilterGroup');
  if (filterGroup && !filterGroup.dataset.listenerAdded) {
    filterGroup.dataset.listenerAdded = '1';
    filterGroup.addEventListener('click', (e) => {
      const btn = e.target.closest('[data-admin-filter]');
      if (!btn) return;
      
      filterGroup.querySelectorAll('.filter-btn').forEach(b => b.classList.remove('active'));
      btn.classList.add('active');
      
      state.adminFilter = btn.dataset.adminFilter;
      loadAdminMemories(true);
    });
  }
  
  // Sort
  const sortSelect = document.getElementById('adminSort');
  if (sortSelect && !sortSelect.dataset.listenerAdded) {
    sortSelect.dataset.listenerAdded = '1';
    sortSelect.addEventListener('change', () => {
      state.adminSort = sortSelect.value;
      loadAdminMemories(true);
    });
  }
  
  // Page size
  const pageSizeSelect = document.getElementById('adminPageSize');
  if (pageSizeSelect && !pageSizeSelect.dataset.listenerAdded) {
    pageSizeSelect.dataset.listenerAdded = '1';
    pageSizeSelect.addEventListener('change', () => {
      state.adminLimit = parseInt(pageSizeSelect.value, 10);
      loadAdminMemories(true);
    });
  }
}

// ═══════════════════════════════════════════════════════════════════════════════
// LOAD ADMIN MEMORIES
// ═══════════════════════════════════════════════════════════════════════════════

async function loadAdminMemories(reset = false, preserveBulk = false) {
  if (!state.adminToken) {
    console.warn('⚠️ No admin token');
    return;
  }
  
  if (reset) {
    state.adminPage = 1;
    state.adminHasMore = true;
    if (!preserveBulk) {
      state.adminSelectedIds.clear();
      state.adminBulkMode = false;
    }
    updateBulkToggleUI();
  }
  
  if (!state.adminHasMore) return;
  
  try {
    const params = new URLSearchParams({
      filter: state.adminFilter,
      sort: state.adminSort,
      search: state.adminSearch || '',
      page: String(state.adminPage),
      limit: String(state.adminLimit)
    });
    
    const res = await fetch(apiUrl(`/api/admin/memories?${params}`), {
      headers: { 'Authorization': `Bearer ${state.adminToken}` }
    });
    
    const data = await res.json();
    
    if (!data.success) {
      if (res.status === 401) adminLogout();
      console.error('❌ Failed:', data.error);
      return;
    }
    
    updateAdminStats(data.stats);
    renderAdminGrid(data.memories || [], reset);
    state.adminHasMore = !!data.hasMore;
    state.adminPage += 1;
    
  } catch (e) {
    console.error('❌ Error:', e);
    showNotification('error', 'Error', 'Failed to load memories');
  }
}

function adminLoadMore() {
  loadAdminMemories(false);
}

// ═══════════════════════════════════════════════════════════════════════════════
// UPDATE STATS
// ═══════════════════════════════════════════════════════════════════════════════

function updateAdminStats(stats) {
  if (!stats) return;
  const setContent = (id, val) => {
    const el = document.getElementById(id);
    if (el) el.textContent = val ?? '0';
  };
  setContent('statTotal', stats.total);
  setContent('statApproved', stats.approved);
  setContent('statPending', stats.pending);
  setContent('statStorage', stats.totalSizeFormatted || '0 MB');
}

// ═══════════════════════════════════════════════════════════════════════════════
// RENDER ADMIN GRID WITH PROPER IMAGE STRUCTURE
// ═══════════════════════════════════════════════════════════════════════════════

function renderAdminGrid(memories, reset) {
  const grid = document.getElementById('adminGrid');
  if (!grid) return;
  
  const items = (memories || []).map(m => ({
    ...m,
    file_url: mediaUrl(m.file_url)
  }));
  
  if (reset) grid.innerHTML = '';
  
  if (!items.length && reset) {
    grid.innerHTML = `<div class="admin-grid-empty">📭 No memories found</div>`;
    return;
  }
  
  grid.insertAdjacentHTML('beforeend', items.map(memory => {
    const statusClass = memory.purgedAt ? 'status-trash' : 
                       (memory.deletedAt ? 'status-trash' : 
                       (memory.approved ? 'status-approved' : 'status-pending'));
    const statusText = memory.deletedAt ? 'TRASH' : (memory.approved ? 'APPROVED' : 'PENDING');
    const statusIcon = memory.deletedAt ? '🗑' : (memory.approved ? '✓' : '⏳');
    
    const bulkCheckbox = state.adminBulkMode ? `
      <div class="bulk-checkbox-wrapper">
        <input type="checkbox" class="bulk-checkbox"
               onchange="toggleSelectId(${memory.id}, this.checked)" 
               ${state.adminSelectedIds.has(memory.id) ? 'checked' : ''}/>
      </div>` : '';
    
    const canMod = can('moderation');
    const canEdit = can('editMemory');
    
    return `
      <div class="admin-memory-card" data-id="${memory.id}">
        <!-- PROPERLY STRUCTURED MEDIA SECTION -->
        <div class="admin-memory-media">
          ${bulkCheckbox}
          ${memory.file_type === 'video' 
            ? `<video src="${memory.file_url}" preload="metadata"></video>` 
            : `<img src="${memory.file_url}" alt="${escapeHtml(memory.student_name || 'Memory')}" loading="lazy">`}
          <span class="admin-memory-status ${statusClass}">${statusIcon} ${statusText}</span>
        </div>
        
        <!-- INFO SECTION -->
        <div class="admin-memory-info">
          <div class="admin-memory-name">${escapeHtml(memory.student_name || 'Unknown')}</div>
          <div class="admin-memory-caption">${escapeHtml(memory.caption || 'No caption')}</div>
          <div class="admin-memory-meta">
            <span>📁 ${escapeHtml(memory.memory_type || 'General')}</span>
            <span>📦 ${escapeHtml(memory.file_size_formatted || 'N/A')}</span>
          </div>
          <div class="admin-memory-meta">
            <span>❤️ ${memory.likes || 0} likes</span>
            <span>📅 ${escapeHtml(timeAgo(memory.created_at))}</span>
          </div>
        </div>
        
        <!-- ACTION BUTTONS -->
        <div class="admin-memory-actions">
          ${(!memory.approved && !memory.deletedAt && canMod) 
            ? `<button class="approve-btn" onclick="approveMemory(${memory.id})">✓ Approve</button>` 
            : `<button class="approve-btn" style="opacity:0.5;" disabled>✓ Approve</button>`}
          <button class="download-btn" onclick="window.open('${memory.file_url}', '_blank')">⬇ Download</button>
          ${!memory.deletedAt 
            ? `<button class="delete-btn" onclick="trashMemory(${memory.id})">🗑 Trash</button>` 
            : `<button class="restore-btn" onclick="restoreMemory(${memory.id})">↩ Restore</button>`}
          ${canEdit 
            ? `<button class="edit-btn" onclick="openEditMemory(${memory.id})">✏ Edit</button>` 
            : `<button class="edit-btn" style="opacity:0.5;" disabled>✏ Edit</button>`}
        </div>
      </div>`;
  }).join(''));
}

// ═══════════════════════════════════════════════════════════════════════════════
// MEMORY ACTIONS
// ═══════════════════════════════════════════════════════════════════════════════

async function approveMemory(id) {
  try {
    const res = await fetch(apiUrl(`/api/admin/approve/${id}`), {
      method: 'POST',
      headers: { 'Authorization': `Bearer ${state.adminToken}` }
    });
    const data = await res.json();
    if (data.success) {
      showNotification('success', 'Approved', 'Memory approved.');
      loadAdminMemories(true);
      if (typeof loadMemories === 'function') loadMemories(true);
    } else {
      showNotification('error', 'Failed', data.error || 'Could not approve.');
    }
  } catch (e) {
    showNotification('error', 'Failed', e.message);
  }
}

async function trashMemory(id) {
  if (!confirm('Move this memory to Trash?')) return;
  try {
    const res = await fetch(apiUrl(`/api/admin/delete/${id}`), {
      method: 'DELETE',
      headers: { 'Authorization': `Bearer ${state.adminToken}` }
    });
    const data = await res.json();
    if (data.success) {
      showNotification('success', 'Trashed', 'Moved to trash.');
      loadAdminMemories(true);
      if (typeof loadMemories === 'function') loadMemories(true);
    } else {
      showNotification('error', 'Failed', data.error || 'Could not trash.');
    }
  } catch (e) {
    showNotification('error', 'Failed', e.message);
  }
}

async function restoreMemory(id) {
  try {
    const res = await fetch(apiUrl(`/api/admin/restore/${id}`), {
      method: 'POST',
      headers: { 'Authorization': `Bearer ${state.adminToken}` }
    });
    const data = await res.json();
    if (data.success) {
      showNotification('success', 'Restored', 'Memory restored.');
      loadAdminMemories(true);
      if (typeof loadMemories === 'function') loadMemories(true);
    } else {
      showNotification('error', 'Failed', data.error || 'Could not restore.');
    }
  } catch (e) {
    showNotification('error', 'Failed', e.message);
  }
}

async function purgeMemory(id) {
  if (!confirm('Purge permanently? This cannot be undone.')) return;
  try {
    const res = await fetch(apiUrl(`/api/admin/purge/${id}`), {
      method: 'DELETE',
      headers: { 'Authorization': `Bearer ${state.adminToken}` }
    });
    const data = await res.json();
    if (data.success) {
      showNotification('success', 'Purged', 'Deleted permanently.');
      loadAdminMemories(true);
      if (typeof loadMemories === 'function') loadMemories(true);
    } else {
      showNotification('error', 'Failed', data.error || 'Could not purge.');
    }
  } catch (e) {
    showNotification('error', 'Failed', e.message);
  }
}

// ═══════════════════════════════════════════════════════════════════════════════
// BULK SELECTION
// ═══════════════════════════════════════════════════════════════════════════════

function toggleBulkSelect() {
  state.adminBulkMode = !state.adminBulkMode;
  if (!state.adminBulkMode) state.adminSelectedIds.clear();
  updateBulkToggleUI();
  loadAdminMemories(true, true);
}

function updateBulkToggleUI() {
  const btn = document.getElementById('bulkSelectToggle');
  if (btn) {
    btn.textContent = state.adminBulkMode ? '☑ Bulk Select: ON' : '☐ Bulk Select: OFF';
  }
}

function toggleSelectId(id, checked) {
  if (checked) {
    state.adminSelectedIds.add(id);
  } else {
    state.adminSelectedIds.delete(id);
  }
}

async function bulkActionPrompt(action) {
  if (!can('bulk')) {
    return showNotification('error', 'No permission', 'You cannot do bulk actions.');
  }
  
  if (!state.adminBulkMode) {
    return showNotification('info', 'Enable bulk select', 'Turn Bulk Select ON first.');
  }
  
  const ids = Array.from(state.adminSelectedIds);
  if (!ids.length) {
    return showNotification('info', 'Select items', 'Select at least one memory.');
  }
  
  let memoryType = undefined;
  if (action === 'setType') {
    memoryType = prompt('Enter new category:', 'Friends');
    if (!memoryType) return;
  }
  
  if (!confirm(`Run "${action}" on ${ids.length} item(s)?`)) return;
  
  try {
    const res = await fetch(apiUrl(`/api/admin/bulk`), {
      method: 'POST',
      headers: {
        'Content-Type': 'application/json',
        'Authorization': `Bearer ${state.adminToken}`
      },
      body: JSON.stringify({ action, ids, memoryType })
    });
    const data = await res.json();
    if (data.success) {
      showNotification('success', 'Bulk done', `${data.changed} updated.`);
      state.adminSelectedIds.clear();
      loadAdminMemories(true, true);
      if (typeof loadMemories === 'function') loadMemories(true);
    } else {
      showNotification('error', 'Failed', data.error || 'Bulk failed.');
    }
  } catch (e) {
    showNotification('error', 'Failed', e.message);
  }
}

// ═══════════════════════════════════════════════════════════════════════════════
// EDIT MEMORY
// ═══════════════════════════════════════════════════════════════════════════════

async function openEditMemory(id) {
  const name = prompt('Student name:');
  const caption = prompt('Caption:');
  const type = prompt('Category:');
  
  const payload = {};
  if (name !== null && name.trim()) payload.student_name = name;
  if (caption !== null && caption.trim()) payload.caption = caption;
  if (type !== null && type.trim()) payload.memory_type = type;
  
  if (!Object.keys(payload).length) return;
  
  try {
    const res = await fetch(apiUrl(`/api/admin/memory/edit/${id}`), {
      method: 'POST',
      headers: {
        'Content-Type': 'application/json',
        'Authorization': `Bearer ${state.adminToken}`
      },
      body: JSON.stringify(payload)
    });
    const data = await res.json();
    if (data.success) {
      showNotification('success', 'Saved', 'Memory updated.');
      loadAdminMemories(true);
      if (typeof loadMemories === 'function') loadMemories(true);
    } else {
      showNotification('error', 'Failed', data.error || 'Edit failed.');
    }
  } catch (e) {
    showNotification('error', 'Failed', e.message);
  }
}

// ═══════════════════════════════════════════════════════════════════════════════
// EXPOSE FUNCTIONS GLOBALLY
// ═══════════════════════════════════════════════════════════════════════════════

window.initModerationPanelContent = initModerationPanelContent;
window.loadAdminMemories = loadAdminMemories;
window.adminLoadMore = adminLoadMore;
window.approveMemory = approveMemory;
window.trashMemory = trashMemory;
window.restoreMemory = restoreMemory;
window.purgeMemory = purgeMemory;
window.toggleBulkSelect = toggleBulkSelect;
window.toggleSelectId = toggleSelectId;
window.bulkActionPrompt = bulkActionPrompt;
window.openEditMemory = openEditMemory;

console.log('✅ Admin Moderation Module Loaded');
</script>
